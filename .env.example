# ============================================
# Personal Finance App - Environment Variables
# ============================================

# Database (mặc định SQLite, đổi sang PostgreSQL khi cần)
DATABASE_URL=sqlite:///data/finance.db
# Ví dụ Supabase (khuyến nghị cho Streamlit Cloud):
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require

# Admin mặc định (tạo khi khởi tạo lần đầu)
ADMIN_USERNAME=bibibunbo
ADMIN_PASSWORD=pony
ADMIN_DISPLAY_NAME=Quản trị viên

# Secret key cho session
SECRET_KEY=change-this-to-a-random-string-in-production

# API Providers
VNAPPMOB_BASE_URL=https://api.vnappmob.com/api
VNAPPMOB_EXCHANGE_SCOPE=exchange_rate
VNAPPMOB_GOLD_SCOPE=gold

# Vietcombank XML fallback
VCB_EXCHANGE_URL=https://portal.vietcombank.com.vn/Usercontrols/TVPortal.TyGia/pXML.aspx?b=10

# Cache TTL (seconds)
RATE_CACHE_TTL=1800
GOLD_CACHE_TTL=1800
TOKEN_TTL=3600

# Backup
AUTO_BACKUP_ON_START=true
MAX_BACKUPS=10
